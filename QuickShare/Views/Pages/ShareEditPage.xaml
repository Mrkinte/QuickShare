<Page
    x:Class="QuickShare.Views.Pages.ShareEditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:QuickShare.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ui:NavigationView.HeaderContent="编辑"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:TextBlock VerticalAlignment="Center" Text="添加" />
                <ui:Button
                    Margin="12,0,0,0"
                    Command="{Binding AddFilesToShareRecordCommand}"
                    Content="文件">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Foreground="DeepSkyBlue" Symbol="Document24" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button
                    Margin="12,0,0,0"
                    Command="{Binding AddDirectoryToShareRecordCommand}"
                    Content="文件夹">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Foreground="Orange" Symbol="Folder24" />
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button
                    Appearance="{Binding ModifyBtnAppearance}"
                    Command="{Binding ConfirmModifyCommand}"
                    Content="确认修改"
                    IsEnabled="{Binding ModifyBtnEnabled}">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Checkmark24" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button
                    Margin="12,0,0,0"
                    Command="{Binding ExitEditCommand}"
                    Content="退出编辑">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Foreground="Green" Symbol="ArrowLeft24" />
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Grid>
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,12"
            Orientation="Horizontal">
            <ui:TextBlock VerticalAlignment="Center" Text="备注" />
            <ui:TextBox
                MinWidth="360"
                Margin="12,0,0,0"
                ClearButtonEnabled="False"
                PlaceholderText="请在此输入分享备注"
                Text="{Binding Description, Mode=TwoWay}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="TextChanged">
                        <i:InvokeCommandAction Command="{Binding ConfirmModifyEnableCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ui:TextBox>
            <ui:TextBlock
                Margin="24,0,0,0"
                VerticalAlignment="Center"
                Text="验证码" />
            <ui:TextBox
                Width="100"
                Margin="12,0,0,0"
                ClearButtonEnabled="False"
                MaxLength="4"
                Text="{Binding VerificationCode, Mode=TwoWay}"
                TextAlignment="Center">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="TextChanged">
                        <i:InvokeCommandAction Command="{Binding ConfirmModifyEnableCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </ui:TextBox>
            <ui:Button
                Margin="8,0,0,0"
                Padding="8"
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding RandomVerificationCodeCommand}"
                Icon="{ui:SymbolIcon Symbol=ArrowSync24}" />
        </StackPanel>
        <ui:BreadcrumbBar
            Grid.Row="2"
            VerticalAlignment="Center"
            Command="{Binding FolderSelectedCommand, Mode=OneWay}"
            ItemsSource="{Binding Folders, Mode=OneWay}">
            <ui:BreadcrumbBar.ItemTemplate>
                <DataTemplate>
                    <TextBlock
                        Cursor="Hand"
                        Foreground="Orange"
                        Text="{Binding FileName, Mode=OneTime}" />
                </DataTemplate>
            </ui:BreadcrumbBar.ItemTemplate>
        </ui:BreadcrumbBar>
        <ui:DataGrid
            x:Name="DataGrid"
            Grid.Row="3"
            Margin="0,0,0,12"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            ItemsSource="{Binding FileRecords, Mode=OneWay}">
            <ui:DataGrid.Resources>
                <ContextMenu x:Key="CellContextMenu">
                    <MenuItem
                        Command="{Binding Source={x:Reference DataGrid}, Path=DataContext.CopyFilePathCommand}"
                        CommandParameter="{Binding}"
                        Header="复制路径">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Copy24" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <MenuItem
                        Command="{Binding Source={x:Reference DataGrid}, Path=DataContext.ShowInExplorerCommand}"
                        CommandParameter="{Binding}"
                        Header="在资源管理器中打开">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Open24" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </ui:DataGrid.Resources>
            <!--  Style  -->
            <ui:DataGrid.ColumnHeaderStyle>
                <Style BasedOn="{StaticResource DefaultDataGridColumnHeaderStyle}" TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
            </ui:DataGrid.ColumnHeaderStyle>
            <ui:DataGrid.CellStyle>
                <Style BasedOn="{StaticResource DefaultDataGridCellStyle}" TargetType="DataGridCell">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                </Style>
            </ui:DataGrid.CellStyle>

            <ui:DataGrid.Columns>
                <DataGridTemplateColumn Width="*" Header="文件（文件夹）">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource DefaultDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="ContextMenu" Value="{StaticResource CellContextMenu}" />
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Grid.Column="0">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon">
                                            <Setter Property="Symbol" Value="Document24" />
                                            <Setter Property="Foreground" Value="DeepSkyBlue" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                    <Setter Property="Symbol" Value="Folder24" />
                                                    <Setter Property="Foreground" Value="Orange" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                                <ui:TextBlock
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Cursor="Hand"
                                    Text="{Binding FileName, Mode=OneWay}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonDown">
                                            <i:InvokeCommandAction Command="{Binding DataContext.OpenSubDirectoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ui:TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    MinWidth="100"
                    Binding="{Binding DownloadCount, Mode=OneWay}"
                    Header="大小"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    MinWidth="100"
                    Binding="{Binding DownloadCount, Mode=OneWay}"
                    Header="下载次数"
                    IsReadOnly="True" />
                <DataGridTemplateColumn Width="Auto" Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ui:Button
                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                CommandParameter="{Binding}"
                                Content="删除">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Foreground="Red" Symbol="Delete24" />
                                </ui:Button.Icon>
                            </ui:Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </ui:DataGrid.Columns>
        </ui:DataGrid>
    </Grid>
</Page>
