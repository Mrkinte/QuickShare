<Page
    x:Class="QuickShare.Views.Pages.TransmitRecordsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:QuickShare.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="TransmitRecordsPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:TextBlock
                    Margin="0,0,12,0"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Text="待定" />
            </StackPanel>

            <ui:Button
                Grid.Column="1"
                HorizontalAlignment="Right"
                Command="{Binding CleanAllTransmitRecordsCommand}"
                Content="清空记录">
                <ui:Button.Icon>
                    <ui:SymbolIcon Foreground="LightSeaGreen" Symbol="Broom24" />
                </ui:Button.Icon>
            </ui:Button>
        </Grid>
        <ui:DataGrid
            Grid.Row="1"
            Margin="0,12,0,12"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            ItemsSource="{Binding TransmitRecords, Mode=OneWay}">
            <!--  Style  -->
            <DataGrid.ColumnHeaderStyle>
                <Style BasedOn="{StaticResource DefaultDataGridColumnHeaderStyle}" TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style BasedOn="{StaticResource DefaultDataGridCellStyle}" TargetType="DataGridCell">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="MinHeight" Value="40" />
                </Style>
            </DataGrid.CellStyle>

            <!--  Content  -->
            <ui:DataGrid.Columns>
                <DataGridTextColumn
                    Width="Auto"
                    MinWidth="160"
                    Binding="{Binding Time, Mode=OneWay}"
                    Header="时间"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="Auto"
                    MinWidth="80"
                    Binding="{Binding Type, Mode=OneWay}"
                    Header="类型"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="Auto"
                    MinWidth="80"
                    Binding="{Binding Direction, Mode=OneWay}"
                    Header="方向"
                    IsReadOnly="True" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Description, Mode=OneWay}"
                    Header="文件（消息）"
                    IsReadOnly="True" />
                <DataGridTemplateColumn
                    Width="Auto"
                    MinWidth="260"
                    Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Command="{Binding DataContext.ViewTransmitRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="详情">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Foreground="DeepSkyBlue" Symbol="ContentView24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <ui:Button
                                    Margin="12,0,0,0"
                                    Command="{Binding DataContext.DeleteTransmitRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="删除">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Foreground="Red" Symbol="Delete24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </ui:DataGrid.Columns>
        </ui:DataGrid>
    </Grid>
</Page>
